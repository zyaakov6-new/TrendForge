# TrendForge — Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and should NEVER be committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — get at https://console.anthropic.com
# Used server-side only (AI market generation)
ANTHROPIC_API_KEY=sk-ant-...

# WalletConnect Cloud project ID — register at https://cloud.walletconnect.com
# Required for wallet connections (MetaMask, Coinbase, WalletConnect QR, etc.)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Admin wallet address (lowercase 0x...) — the wallet that can access /moderate
# Server-side check (API auth)
ADMIN_WALLET=0x...your_wallet_address...
# Client-side check (show/hide the moderation UI)
NEXT_PUBLIC_ADMIN_WALLET=0x...your_wallet_address...

# ── Optional: Persistent Market Queue (recommended for production) ─────────────
#
# Without these: pending markets are stored in-memory + /tmp (works for local dev,
# will lose data across Vercel Lambda cold starts in production).
#
# With these: markets are stored in Upstash Redis (persistent, survives restarts,
# works across multiple Vercel Lambda instances).
#
# Setup: create a free database at https://upstash.com → Redis → Create Database
# Then copy the REST URL and token from the database dashboard.

# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Optional: CLOB API key (required when going live with real order placement) ──
#
# Polymarket CLOB requires a per-wallet API key derived by signing a message.
# For Kuest self-hosted, this depends on your CLOB backend configuration.
# See lib/clob.ts → submitOrder() for the derivation instructions.

# NEXT_PUBLIC_CLOB_API_KEY=
# NEXT_PUBLIC_CLOB_BASE_URL=https://clob.polymarket.com

# ── Optional: Custom Kuest backend URLs ───────────────────────────────────────
#
# If you're running a self-hosted Kuest instance, point these at your own URLs.
# Defaults: Polymarket's public Gamma API (read-only market data, no auth needed).

# NEXT_PUBLIC_GAMMA_BASE_URL=https://gamma-api.polymarket.com
